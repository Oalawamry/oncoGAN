{
    "name": "oncoGAN-debug",
    "image": "oncogan:v1.0.0_devcontainer",

    "workspaceFolder": "/workspace/.devcontainer/oncogan_devcontainer.code-workspace", // VSCode workspace folder inside the container
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",

    "mounts": [
        "source=${localWorkspaceFolder}/src,target=/oncoGAN,type=bind",
        "source=${localWorkspaceFolder}/models,target=/oncoGAN/models,type=bind",
        "source=${localWorkspaceFolder}/trained_models_v1,target=/oncoGAN/trained_models,type=bind",
        "source=${localWorkspaceFolder}/test/hg19,target=/reference,type=bind"
    ],

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.isort",
                "oderwat.indent-rainbow",
                "usernamehw.errorlens",
                "exodiusstudios.comment-anchors",
                "esbenp.prettier-vscode",
                "github.remotehub"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/opt/conda/bin/python3.10"
            }
        }
    },

    // Optional: if you need to run things as root or a specific user
    "remoteUser": "mambauser" 
}